// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EVALUATOR // Delegado Grupo Disciplinar
  TEACHER // Professor Avaliado
}

enum CopyrightStatus {
  SIM
  NAO
  DUVIDAS
}

model DisciplinaryGroup {
  id   String @id @default(uuid())
  name String @unique // ex: Línguas, Matemática

  users    User[]
  subjects Subject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String  @id @default(uuid())
  name     String
  username String? @unique
  password String? // Hashed via bcrypt, nullable for teachers
  role     Role    @default(TEACHER)

  // Associar o delegado ao seu grupo disciplinar
  disciplinaryGroupId String?
  disciplinaryGroup   DisciplinaryGroup? @relation(fields: [disciplinaryGroupId], references: [id])

  // Disciplinas que este professor leciona
  taughtSubjects Subject[] @relation("SubjectTeachers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos de avaliações
  evaluationsGiven    Evaluation[] @relation("EvaluatorRelation")
  evaluationsReceived Evaluation[] @relation("TeacherRelation")
}

model Course {
  id        String   @id @default(uuid())
  name      String // ex: Informática de Gestão
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subjects Subject[]
}

model Subject {
  id   String @id @default(uuid())
  name String // ex: Sistemas de Informação
  year Int? // 1, 2, 3, 10, 11, etc.

  // Uma disciplina pertence a um grupo disciplinar
  disciplinaryGroupId String?
  disciplinaryGroup   DisciplinaryGroup? @relation(fields: [disciplinaryGroupId], references: [id])

  // Uma disciplina pertence a um curso
  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  // Os professores que a lecionam
  teachers User[] @relation("SubjectTeachers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evaluations Evaluation[]
}

model Evaluation {
  id         String @id @default(uuid())
  schoolYear String // ex: 2025/2026

  scoreAdequacy     Int // A) Adequação aos programas
  scoreScientific   Int // B) Qualidade científica dos textos...
  scoreQuantity     Int // C) Quantidade dos textos...
  scoreBibliography Int // D) Bibliografia identificada

  justification   String?
  copyrightStatus CopyrightStatus
  observations    String?

  evaluatorId String
  evaluator   User   @relation("EvaluatorRelation", fields: [evaluatorId], references: [id])

  teacherId String
  teacher   User   @relation("TeacherRelation", fields: [teacherId], references: [id])

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  modules String // Texto livre para os módulos

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
